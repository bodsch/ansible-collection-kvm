#jinja2: trim_blocks: True, lstrip_blocks: True
#cloud-config
hostname: {{ hostname }}
fqdn: {{ hostname }}.{{ domain }}
manage_etc_hosts: true
timezone: Europe/Berlin

package_update: true
package_upgrade: true
package_reboot_if_required: true
packages: [qemu-guest-agent, curl, vim, nano, iproute2]

ssh_pwauth: false
disable_root: true

users:
  - name: admin
    groups: [sudo, adm]
    shell: /bin/bash
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    lock_passwd: true
{% if ssh_public_keys %}
    ssh_authorized_keys:
  {% for key in if ssh_public_keys %}
      - {{ key | quote }}
  {% endfor %}
{% endif %}
growpart: { mode: auto, devices: ["/"], ignore_growroot_disabled: false }

runcmd:
  - systemctl enable --now qemu-guest-agent
